#!/bin/bash
# spm-to-xcframework — Build xcframeworks from Swift Package Manager packages.
#
# Takes an SPM package URL (or local path) and produces ready-to-use
# xcframeworks for each library product (Swift, Objective-C, or mixed),
# suitable for .NET binding generation or any other xcframework consumer.
#
# Usage:
#   spm-to-xcframework <package-url-or-path> --version <ver> [options]
#
# Examples:
#   spm-to-xcframework https://github.com/Alamofire/Alamofire.git -v 5.10.2
#   spm-to-xcframework https://github.com/kean/Nuke.git -v 12.8.0 -o ./output
#   spm-to-xcframework ./local-package -o ./output --product MyLib
#   spm-to-xcframework https://github.com/stripe/stripe-ios.git -v 25.6.2 --product Stripe --target StripeCore --target StripeUICore
#   spm-to-xcframework https://github.com/nicklockwood/iCarousel.git -v 1.8.3 --binary

set -euo pipefail

# --- Colors ---
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
DIM='\033[2m'
NC='\033[0m'

# --- Globals ---
PACKAGE_SOURCE=""        # URL or local path
VERSION=""               # Tag/version
OUTPUT_DIR=""            # Output directory (default: ./xcframeworks)
PRODUCT_FILTERS=()       # Build only these products (default: all)
TARGET_FILTERS=()        # Build SPM targets that aren't exposed as library products (escape hatch)
TARGET_ENTRIES=()        # Names from TARGET_FILTERS that passed verification (used by build_product)
REVISION=""              # Expected commit SHA for tag verification
MIN_IOS="15.0"           # Minimum iOS deployment target
INCLUDE_DEPS=false       # Also output dependency xcframeworks
BINARY_MODE=false        # Download pre-built xcframeworks from binary targets
VERBOSE=false            # Show full build output
DRY_RUN=false            # Show what would be built
WORK_DIR=""              # Temp working directory (set in main)
KEEP_WORK=false          # Keep work directory on exit (for debugging)
HAS_XCODEPROJ=false      # Package has its own .xcodeproj (set in fetch_source)
LAST_BUILT_FW_NAME=""    # Resolved framework name from last build_product (for --include-deps)

# Counters
BUILT=0
FAILED=0
SKIPPED=0

# --- Utilities ---

die() { echo -e "${RED}Error: $*${NC}" >&2; exit 1; }
info() { echo -e "${CYAN}$*${NC}"; }
success() { echo -e "${GREEN}$*${NC}"; }
warn() { echo -e "${YELLOW}$*${NC}"; }
dim() { echo -e "${DIM}$*${NC}"; }
bold() { echo -e "${BOLD}$*${NC}"; }

verbose_log() {
    if $VERBOSE; then
        echo -e "${DIM}$*${NC}"
    fi
}

cleanup() {
    if [[ -n "$WORK_DIR" && -d "$WORK_DIR" ]]; then
        if $KEEP_WORK; then
            dim "Work directory retained: $WORK_DIR"
        else
            dim "Cleaning up work directory..."
            rm -rf "$WORK_DIR"
        fi
    fi
}

trap cleanup EXIT

# --- Argument Parsing ---

print_help() {
    cat <<'HELP'
spm-to-xcframework — Build xcframeworks from Swift Package Manager packages.

Supports Swift, Objective-C, and mixed-language library products. Each
xcframework is ready for .NET binding generation (Swift.Bindings) or any
other xcframework consumer.

USAGE
    spm-to-xcframework <package-url-or-path> --version <ver> [options]

ARGUMENTS
    <package-url-or-path>   Git URL or local filesystem path to the SPM package

OPTIONS
    -v, --version <ver>     Git tag to check out (required for remote URLs)
    -o, --output <dir>      Output directory (default: ./xcframeworks)
    -p, --product <name>    Build only this product (repeatable for multiple products)
    -t, --target <name>     Build an SPM target that isn't exposed as a .library() product
                            (repeatable). Escape hatch for packages like stripe-ios that ship
                            important modules only as .target(...). WARNING: this enables
                            MACH_O_TYPE=mh_dylib for the build, which forces ALL link steps to
                            produce dynamic libs. Do NOT use with packages that have internal
                            C/ObjC dependency targets (Firebase/nanopb/leveldb/GoogleUtilities,
                            etc.) — those targets will fail to link. Use only for packages
                            whose targets are truly standalone dynamic modules (Stripe is fine).
        --binary            Download pre-built xcframeworks from binary SPM targets
        --revision <sha>    Verify git tag resolves to this commit SHA before building
        --min-ios <ver>     Minimum iOS deployment target (default: 15.0)
        --include-deps      Also build xcframeworks for transitive dependencies
        --verbose           Show full build output
        --dry-run           Show what would be built without building
        --keep-work         Keep temporary work directory (for debugging)
    -h, --help              Show this help

EXAMPLES
    # Build all products from Alamofire (Swift)
    spm-to-xcframework https://github.com/Alamofire/Alamofire.git -v 5.10.2

    # Build just the Nuke product, output to custom dir
    spm-to-xcframework https://github.com/kean/Nuke.git -v 12.8.0 -o ./nuke-fw

    # Build from a local package (Swift, ObjC, or mixed)
    spm-to-xcframework ./MyPackage -o ./output

    # Build multiple specific products from Stripe
    spm-to-xcframework https://github.com/stripe/stripe-ios.git -v 25.6.2 \
        --product Stripe --product StripePayments

    # Mix products and internal-only targets (Stripe ships StripeCore/StripeUICore as
    # .target(...) rather than .library(...), so --target is the only way to build them)
    spm-to-xcframework https://github.com/stripe/stripe-ios.git -v 25.6.2 \
        --product Stripe --target StripeCore --target StripeUICore

    # Download pre-built binary xcframeworks
    spm-to-xcframework https://github.com/nicklockwood/iCarousel.git -v 1.8.3 --binary

    # Verify tag SHA before building (supply-chain security)
    spm-to-xcframework https://github.com/kean/Nuke.git -v 12.8.0 \
        --revision abc123def456...

OUTPUT
    Creates one .xcframework per library product in the output directory.
    Each xcframework contains device (arm64) and simulator slices, built with
    BUILD_LIBRARY_FOR_DISTRIBUTION=YES for ABI stability.

    Framework type is auto-detected and reported:
    - Swift:  Has .swiftinterface files (binding via ABI JSON)
    - ObjC:   Has headers + modulemap, no Swift (binding via clang AST)
    - Mixed:  Has both Swift interfaces and ObjC headers

    These xcframeworks are ready for use with:
    - Swift.Bindings (.NET binding generator — Swift, ObjC, and mixed)
    - Direct Xcode integration
    - Any xcframework consumer
HELP
}

parse_args() {
    # Helper: die if a value-taking flag has no argument or its argument looks like another flag.
    require_value() {
        if [[ $# -lt 2 || "$2" == -* ]]; then
            die "$1 requires a value."
        fi
    }

    while [[ $# -gt 0 ]]; do
        case $1 in
            -v|--version) require_value "$@"; VERSION="$2"; shift 2 ;;
            -o|--output) require_value "$@"; OUTPUT_DIR="$2"; shift 2 ;;
            -p|--product) require_value "$@"; PRODUCT_FILTERS+=("$2"); shift 2 ;;
            -t|--target) require_value "$@"; TARGET_FILTERS+=("$2"); shift 2 ;;
            --min-ios) require_value "$@"; MIN_IOS="$2"; shift 2 ;;
            --revision) require_value "$@"; REVISION="$2"; shift 2 ;;
            --binary) BINARY_MODE=true; shift ;;
            --include-deps) INCLUDE_DEPS=true; shift ;;
            --verbose) VERBOSE=true; shift ;;
            --dry-run) DRY_RUN=true; shift ;;
            --keep-work) KEEP_WORK=true; shift ;;
            -h|--help) print_help; exit 0 ;;
            -*)
                die "Unknown option: $1\nRun with --help for usage."
                ;;
            *)
                if [[ -z "$PACKAGE_SOURCE" ]]; then
                    PACKAGE_SOURCE="$1"
                else
                    die "Unexpected argument: $1\nPackage source already set to: $PACKAGE_SOURCE"
                fi
                shift
                ;;
        esac
    done

    [[ -n "$PACKAGE_SOURCE" ]] || die "Package URL or path is required.\nRun with --help for usage."
    if [[ -z "$OUTPUT_DIR" ]]; then
        OUTPUT_DIR="./xcframeworks"
    fi
}

# --- Package Resolution ---

# Determine if PACKAGE_SOURCE is a local path or remote URL.
is_remote() {
    [[ "$PACKAGE_SOURCE" == http://* || "$PACKAGE_SOURCE" == https://* || "$PACKAGE_SOURCE" == git@* || "$PACKAGE_SOURCE" == ssh://* ]]
}

# Normalize VERSION to the actual tag name on the remote.
# Handles the common case where the user passes "1.2.3" but the tag is "v1.2.3".
# Mutates the global VERSION in place so all downstream code uses the resolved tag.
normalize_version_tag() {
    [[ -n "$VERSION" ]] || return 0
    is_remote || return 0

    # Already matches a tag — nothing to do
    if git ls-remote --tags "$PACKAGE_SOURCE" "$VERSION" "refs/tags/$VERSION" 2>/dev/null | grep -q .; then
        return 0
    fi

    # Try with 'v' prefix
    if git ls-remote --tags "$PACKAGE_SOURCE" "v$VERSION" "refs/tags/v$VERSION" 2>/dev/null | grep -q .; then
        warn "Tag '$VERSION' not found, using 'v$VERSION'"
        VERSION="v$VERSION"
        return 0
    fi

    # No match either way — leave VERSION as-is and let downstream fail with a clear error
}

# Verify that a git tag resolves to the expected commit SHA.
# Uses git ls-remote (no clone needed) and handles annotated tags via ^{}.
verify_revision() {
    local url="$1" tag="$2" expected_sha="$3"

    # Validate SHA format (full 40-character hex)
    if ! [[ "$expected_sha" =~ ^[0-9a-f]{40}$ ]]; then
        die "--revision requires a full 40-character SHA (got: $expected_sha)"
    fi

    info "Verifying tag '$tag' resolves to $expected_sha..."

    local ls_output
    ls_output=$(git ls-remote --tags "$url" "refs/tags/$tag" "refs/tags/${tag}^{}" 2>/dev/null) \
        || die "Failed to query remote tags from $url"

    if [[ -z "$ls_output" ]]; then
        die "Tag '$tag' not found in $url"
    fi

    # Prefer the dereferenced (^{}) SHA for annotated tags; fall back to direct
    local actual_sha
    actual_sha=$(echo "$ls_output" | grep '\^{}' | awk '{print $1}')
    if [[ -z "$actual_sha" ]]; then
        actual_sha=$(echo "$ls_output" | head -1 | awk '{print $1}')
    fi

    if [[ "$actual_sha" != "$expected_sha" ]]; then
        die "Revision mismatch for tag '$tag':\n  Expected: $expected_sha\n  Actual:   $actual_sha\nThe tag may have been force-pushed. Aborting for safety."
    fi

    success "  Revision verified ✓"
}

# Clone or copy the package source into $WORK_DIR/source.
fetch_source() {
    local source_dir="$WORK_DIR/source"

    if is_remote; then
        [[ -n "$VERSION" ]] || die "Version (--version) is required for remote package URLs."

        # Verify revision before fetching any source
        if [[ -n "$REVISION" ]]; then
            verify_revision "$PACKAGE_SOURCE" "$VERSION" "$REVISION"
        fi

        info "Cloning $PACKAGE_SOURCE @ $VERSION"
        local clone_args=(--depth 1 --branch "$VERSION")

        if ! git clone "${clone_args[@]}" "$PACKAGE_SOURCE" "$source_dir" 2>&1 | tail -3; then
            die "Failed to clone $PACKAGE_SOURCE at version $VERSION"
        fi
    else
        # Local path
        local abs_path
        abs_path=$(cd "$PACKAGE_SOURCE" 2>/dev/null && pwd) || die "Local path not found: $PACKAGE_SOURCE"
        [[ -f "$abs_path/Package.swift" ]] || die "No Package.swift found at $abs_path"

        info "Copying local package from $abs_path"
        cp -R "$abs_path" "$source_dir"
    fi

    [[ -f "$source_dir/Package.swift" ]] || die "No Package.swift found in package source"

    # Track whether the package has its own Xcode project.
    # When it does, xcodebuild uses xcodeproj schemes (e.g. "Alamofire iOS")
    # instead of auto-generated SPM schemes (e.g. "Alamofire").
    HAS_XCODEPROJ=false
    if find "$source_dir" -maxdepth 1 -name "*.xcodeproj" -type d 2>/dev/null | grep -q .; then
        HAS_XCODEPROJ=true
        verbose_log "Package has .xcodeproj — will use Xcode project schemes"
    fi
}

# Download pre-built xcframeworks from SPM binary targets.
# Creates a temporary package that depends on the target repo, resolves
# dependencies, and copies any xcframeworks found in .build/artifacts/.
fetch_binary_artifacts() {
    local binary_dir="$WORK_DIR/binary-resolve"
    mkdir -p "$binary_dir"

    # Derive a package name from the URL
    local pkg_name
    pkg_name=$(basename "$PACKAGE_SOURCE" .git | tr '-' '_')

    info "Resolving binary artifacts from $PACKAGE_SOURCE @ $VERSION..."

    # Create a temporary Package.swift that depends on the target repo
    cat > "$binary_dir/Package.swift" << PKGEOF
// swift-tools-version:5.7
import PackageDescription

let package = Package(
    name: "binary-resolver",
    platforms: [.iOS(.v15)],
    dependencies: [
        .package(url: "$PACKAGE_SOURCE", exact: "$VERSION"),
    ],
    targets: [
        .target(name: "Dummy", path: "Sources"),
    ]
)
PKGEOF

    # Create a minimal source file so the package is valid
    mkdir -p "$binary_dir/Sources"
    echo "// placeholder" > "$binary_dir/Sources/Dummy.swift"

    # Resolve dependencies — this downloads binary artifacts
    info "  Running swift package resolve..."
    if ! (cd "$binary_dir" && swift package resolve 2>&1 | tail -5); then
        die "Failed to resolve binary package dependencies"
    fi

    # Find xcframeworks in .build/artifacts/
    local found_xcfws=()
    while IFS= read -r xcfw; do
        [[ -n "$xcfw" ]] && found_xcfws+=("$xcfw")
    done < <(find "$binary_dir/.build/artifacts" -name "*.xcframework" -type d 2>/dev/null)

    if [[ ${#found_xcfws[@]} -eq 0 ]]; then
        die "No xcframeworks found in resolved artifacts. Is this a binary-target package?"
    fi

    # Collect available artifact names for filter validation
    local available_names=()
    for xcfw in "${found_xcfws[@]}"; do
        available_names+=("$(basename "$xcfw" .xcframework)")
    done

    # Verify every requested --product exists in artifacts
    if [[ ${#PRODUCT_FILTERS[@]} -gt 0 ]]; then
        local missing=()
        for pf in "${PRODUCT_FILTERS[@]}"; do
            local found=false
            for an in "${available_names[@]}"; do
                [[ "$an" == "$pf" ]] && { found=true; break; }
            done
            $found || missing+=("$pf")
        done
        if [[ ${#missing[@]} -gt 0 ]]; then
            die "Requested product(s) not found in binary artifacts: ${missing[*]}\n  Available: ${available_names[*]}"
        fi
    fi

    # Build the filtered list of names to report and copy
    local filtered_names=()
    for an in "${available_names[@]}"; do
        if [[ ${#PRODUCT_FILTERS[@]} -gt 0 ]]; then
            local matched=false
            for pf in "${PRODUCT_FILTERS[@]}"; do
                [[ "$an" == "$pf" ]] && { matched=true; break; }
            done
            $matched || continue
        fi
        filtered_names+=("$an")
    done

    bold "Found ${#filtered_names[@]} binary xcframework(s):"
    for an in "${filtered_names[@]}"; do
        echo "  - ${an}.xcframework"
    done

    # Dry run — report what was found but skip copying
    if $DRY_RUN; then
        echo ""
        bold "Dry run — would copy to: $OUTPUT_DIR"
        return 0
    fi

    mkdir -p "$OUTPUT_DIR"
    for xcfw in "${found_xcfws[@]}"; do
        local name
        name=$(basename "$xcfw")
        local product_name="${name%.xcframework}"

        # Apply product filter if specified
        if [[ ${#PRODUCT_FILTERS[@]} -gt 0 ]]; then
            local matched=false
            for pf in "${PRODUCT_FILTERS[@]}"; do
                [[ "$product_name" == "$pf" ]] && { matched=true; break; }
            done
            if ! $matched; then
                verbose_log "  Skipping $product_name (not in filter list)"
                continue
            fi
        fi

        echo "  - $name"
        rm -rf "$OUTPUT_DIR/$name"
        cp -R "$xcfw" "$OUTPUT_DIR/$name"

        # Validate the copied xcframework
        detect_framework_type "$OUTPUT_DIR/$name"
        success "  $name ready [$FW_TYPE]"
        BUILT=$((BUILT + 1))
    done
}

# Discover library products from Package.swift.
# Sets PRODUCTS array with entries like "name|targets"
discover_products() {
    local source_dir="$WORK_DIR/source"

    info "Resolving package..."
    local dump_file="$WORK_DIR/package-dump.json"
    local dump_err="$WORK_DIR/package-dump-stderr.txt"
    if ! (cd "$source_dir" && swift package dump-package > "$dump_file" 2>"$dump_err"); then
        echo ""
        warn "swift package dump-package failed:"
        cat "$dump_err" | sed 's/^/  /' >&2
        die "Cannot parse Package.swift — is the swift-tools-version supported?"
    fi

    # Also resolve dependencies so xcodebuild can find everything
    (cd "$source_dir" && swift package resolve 2>&1 | tail -3) \
        || die "Failed to resolve package dependencies"

    # Extract library product names using python3.
    # SPM library products can contain Swift, ObjC, or mixed targets —
    # we discover all of them here; framework type is detected after build.
    PRODUCTS=()
    while IFS= read -r product_name; do
        [[ -n "$product_name" ]] || continue

        # Apply product filter if specified
        if [[ ${#PRODUCT_FILTERS[@]} -gt 0 ]]; then
            local matched=false
            for pf in "${PRODUCT_FILTERS[@]}"; do
                [[ "$product_name" == "$pf" ]] && { matched=true; break; }
            done
            if ! $matched; then
                verbose_log "  Skipping product $product_name (not in filter list)"
                continue
            fi
        elif [[ ${#TARGET_FILTERS[@]} -gt 0 ]]; then
            # --target specified without --product: user wants only the listed targets,
            # not every library product on top. Mirrors how --product alone works as a filter.
            verbose_log "  Skipping product $product_name (only --target was specified)"
            continue
        fi

        PRODUCTS+=("$product_name")
    done < <(python3 -c "
import json, sys
pkg = json.load(open('$dump_file'))
for prod in pkg.get('products', []):
    ptype = prod.get('type', {})
    # Library products have a 'library' key in their type
    if 'library' in ptype or (isinstance(ptype, str) and ptype == 'library'):
        print(prod['name'])
" 2>/dev/null)

    # Verify every requested --product was found (before we add any --target entries)
    if [[ ${#PRODUCT_FILTERS[@]} -gt 0 ]]; then
        local missing=()
        if [[ ${#PRODUCTS[@]} -eq 0 ]]; then
            # Short-circuit: no products matched, so every --product is missing.
            # Avoids iterating an empty array under bash 3.2 + set -u.
            missing=("${PRODUCT_FILTERS[@]}")
        else
            for pf in "${PRODUCT_FILTERS[@]}"; do
                local found=false
                for p in "${PRODUCTS[@]}"; do
                    [[ "$p" == "$pf" ]] && { found=true; break; }
                done
                $found || missing+=("$pf")
            done
        fi
        if [[ ${#missing[@]} -gt 0 ]]; then
            die "Requested product(s) not found in package: ${missing[*]}"
        fi
    fi

    local product_count=${#PRODUCTS[@]}

    # --- Target escape hatch ---
    # Verify each --target name exists in the package's targets[] array and append
    # to PRODUCTS (so the rest of the pipeline treats them uniformly) while tracking
    # them in TARGET_ENTRIES so build_product can apply target-specific build settings.
    if [[ ${#TARGET_FILTERS[@]} -gt 0 ]]; then
        # Collect available target names once for error messages and membership checks
        local available_targets
        available_targets=$(python3 -c "
import json
pkg = json.load(open('$dump_file'))
for t in pkg.get('targets', []):
    print(t['name'])
" 2>/dev/null)

        local tf
        for tf in "${TARGET_FILTERS[@]}"; do
            local found=false
            while IFS= read -r tname; do
                [[ "$tname" == "$tf" ]] && { found=true; break; }
            done <<< "$available_targets"

            if ! $found; then
                echo "" >&2
                warn "Target '$tf' not found in Package.swift targets."
                warn "Available targets:"
                echo "$available_targets" | sed 's/^/    /' >&2
                die "Requested target(s) not found in package: $tf"
            fi

            # Dedupe: skip if this name is already in PRODUCTS (e.g., also passed as --product).
            # Length-check guard because bash 3.2 (macOS) under `set -u` treats an empty
            # "${PRODUCTS[@]}" as unbound.
            local already_listed=false
            if [[ ${#PRODUCTS[@]} -gt 0 ]]; then
                local existing
                for existing in "${PRODUCTS[@]}"; do
                    [[ "$existing" == "$tf" ]] && { already_listed=true; break; }
                done
            fi
            $already_listed && continue

            PRODUCTS+=("$tf")
            TARGET_ENTRIES+=("$tf")
        done
    fi

    if [[ ${#PRODUCTS[@]} -eq 0 ]]; then
        if [[ ${#PRODUCT_FILTERS[@]} -gt 0 || ${#TARGET_FILTERS[@]} -gt 0 ]]; then
            die "No library products or targets matching filters (products: ${PRODUCT_FILTERS[*]:-none}, targets: ${TARGET_FILTERS[*]:-none}) found in package"
        else
            die "No library products found in Package.swift"
        fi
    fi

    echo ""
    if [[ $product_count -gt 0 ]]; then
        bold "Found $product_count library product(s):"
        local i=0
        while [[ $i -lt $product_count ]]; do
            echo "  - ${PRODUCTS[$i]}"
            i=$((i + 1))
        done
    fi
    if [[ ${#TARGET_ENTRIES[@]} -gt 0 ]]; then
        bold "Found ${#TARGET_ENTRIES[@]} target(s) (escape hatch — will build with MACH_O_TYPE=mh_dylib):"
        local t
        for t in "${TARGET_ENTRIES[@]}"; do
            echo "  - $t"
        done
    fi
    echo ""
}

# Returns 0 if $1 is in TARGET_ENTRIES (i.e., came from --target, not --product).
is_target_entry() {
    local name="$1" entry
    [[ ${#TARGET_ENTRIES[@]} -gt 0 ]] || return 1
    for entry in "${TARGET_ENTRIES[@]}"; do
        [[ "$entry" == "$name" ]] && return 0
    done
    return 1
}

# Discover xcodebuild schemes available for this package.
# Populates SCHEME_LIST array.
discover_schemes() {
    local source_dir="$WORK_DIR/source"

    info "Discovering build schemes..."
    local list_file="$WORK_DIR/xcodebuild-list.json"

    (cd "$source_dir" && xcodebuild -list -json > "$list_file" 2>/dev/null) || {
        warn "xcodebuild -list failed; will use product names as scheme names"
        return 0
    }

    # Parse schemes from either workspace or project format
    SCHEME_LIST=()
    while IFS= read -r scheme; do
        [[ -n "$scheme" ]] && SCHEME_LIST+=("$scheme")
    done < <(python3 -c "
import json, sys
data = json.load(open('$list_file'))
# Try workspace format first, then project
container = data.get('workspace', data.get('project', {}))
for s in container.get('schemes', []):
    print(s)
" 2>/dev/null)

    if [[ ${#SCHEME_LIST[@]} -gt 0 ]]; then
        verbose_log "  Available schemes: ${SCHEME_LIST[*]}"
    fi
}

# Find the best matching scheme for a given product name.
# Returns the scheme name on stdout, or empty if no match.
find_scheme_for_product() {
    local product="$1"

    # If no schemes were discovered, use product name directly
    if [[ ${#SCHEME_LIST[@]} -eq 0 ]]; then
        echo "$product"
        return 0
    fi

    # Exact match
    local s
    for s in "${SCHEME_LIST[@]}"; do
        [[ "$s" == "$product" ]] && { echo "$s"; return 0; }
    done

    # Case-insensitive exact match (portable — no bash 4 ${,,} needed)
    for s in "${SCHEME_LIST[@]}"; do
        if echo "$s" | grep -qix "$product"; then
            echo "$s"; return 0
        fi
    done

    # Product name with common platform/convention suffixes
    local suffix
    for suffix in " iOS" "-iOS" " (iOS)" " (ios)" "-ios" "-Package" "iOS" " iPhone"; do
        for s in "${SCHEME_LIST[@]}"; do
            [[ "$s" == "${product}${suffix}" ]] && { echo "$s"; return 0; }
        done
    done

    # No match — return the product name and hope xcodebuild figures it out
    echo "$product"
}

# --- Package Patching ---

# Patch Package.swift to make all library products dynamic frameworks.
#
# Why: We need dynamic frameworks for xcframework output (P/Invoke, ABI JSON).
# The old approach set MACH_O_TYPE=mh_dylib globally on the xcodebuild CLI,
# which forced ALL targets (including internal C/ObjC dependency targets like
# nanopb, leveldb, GoogleUtilities-NSData) to link as dynamic libraries.
# These targets are designed to produce object files or static libraries, so
# the linker fails. By patching Package.swift instead, only library PRODUCTS
# become dynamic — internal dependency targets keep their natural build type.
patch_dynamic_libraries() {
    local pkg_file="$1"
    [[ -f "$pkg_file" ]] || return 0

    # Back up original (only if not already backed up)
    [[ -f "${pkg_file}.original" ]] || cp "$pkg_file" "${pkg_file}.original"

    python3 - "$pkg_file" << 'PYEOF'
import re, sys

pkg_path = sys.argv[1]
with open(pkg_path, 'r') as f:
    content = f.read()

# Walk through content, find .library(...) calls (handling nested parens),
# and ensure each has type: .dynamic.
result = []
i = 0
while i < len(content):
    match = re.match(r'\.library\s*\(', content[i:])
    if not match:
        result.append(content[i])
        i += 1
        continue

    # Found .library( — find the matching closing paren
    start = i
    i += match.end()
    depth = 1
    while i < len(content) and depth > 0:
        if content[i] == '(':
            depth += 1
        elif content[i] == ')':
            depth -= 1
        i += 1

    lib_call = content[start:i]

    if 'type: .dynamic' in lib_call:
        result.append(lib_call)
    elif re.search(r'type:\s*\.\w+', lib_call):
        result.append(re.sub(r'type:\s*\.\w+', 'type: .dynamic', lib_call))
    else:
        # Insert type: .dynamic after name: "..."
        name_match = re.search(r'(name:\s*"[^"]*")', lib_call)
        if name_match:
            pos = name_match.end()
            lib_call = lib_call[:pos] + ', type: .dynamic' + lib_call[pos:]
        result.append(lib_call)

content = ''.join(result)
with open(pkg_path, 'w') as f:
    f.write(content)
PYEOF
}

# --- Build ---

# Run xcodebuild archive for a single destination.
# Always writes full output to $WORK_DIR/.last-build-output (fresh each call)
# so that build_archive can inspect it for scheme-not-found fallback regardless
# of --verbose mode.
# Arguments: source_dir scheme destination archive_path derived_data_path [log_file] [is_target]
# is_target: "true" when building an SPM target (not a .library product) — adds
# MACH_O_TYPE=mh_dylib so the target's static library is linked as a dynamic lib.
run_xcodebuild_archive() {
    local source_dir="$1" scheme="$2" destination="$3" archive_path="$4" dd_path="$5"
    local log_file="${6:-$WORK_DIR/.last-build-output}"
    local is_target="${7:-false}"

    local build_cmd=(
        xcodebuild archive
        -scheme "$scheme"
        -destination "$destination"
        -archivePath "$archive_path"
        -derivedDataPath "$dd_path"
        BUILD_LIBRARY_FOR_DISTRIBUTION=YES
        SKIP_INSTALL=NO
        IPHONEOS_DEPLOYMENT_TARGET="$MIN_IOS"
        GCC_TREAT_WARNINGS_AS_ERRORS=NO
        SWIFT_TREAT_WARNINGS_AS_ERRORS=NO
        OTHER_SWIFT_FLAGS=-no-verify-emitted-module-interface
        -skipPackagePluginValidation
        -skipMacroValidation
    )

    # Target escape hatch: force dynamic linkage for SPM .target(...) entries that
    # can't be patched via .library(type: .dynamic). WARNING: this is a global
    # override that also affects internal C/ObjC dependency targets in the same
    # build, so it's unsafe for packages like Firebase/GoogleUtilities. See the
    # --target flag docs in print_help for the full caveat.
    if [[ "$is_target" == "true" ]]; then
        build_cmd+=(MACH_O_TYPE=mh_dylib)
    fi

    # Capture all output to log file. Caller is responsible for display.
    local rc=0
    (cd "$source_dir" && "${build_cmd[@]}" 2>&1) > "$log_file" || rc=$?
    return $rc
}

# Build device + simulator archives for a product (in parallel).
# If the initial scheme fails with "does not contain a scheme", retries
# sequentially with xcodeproj/xcworkspace moved aside (pure SPM mode).
# Arguments: source_dir scheme product archives_dir derived_data
build_archive() {
    local source_dir="$1" scheme="$2" product="$3" archives_dir="$4" derived_data="$5"
    local device_archive="$archives_dir/${product}-ios-arm64.xcarchive"
    local sim_archive="$archives_dir/${product}-ios-simulator.xcarchive"
    local device_log="$WORK_DIR/.build-output-${product}-device"
    local sim_log="$WORK_DIR/.build-output-${product}-simulator"

    # Target entries (from --target) need MACH_O_TYPE=mh_dylib since SPM .target(...)
    # has no dynamic type to patch. This is the old global mh_dylib override, opt-in
    # per-product via --target — see print_help for the caveat about internal deps.
    local is_target=false
    if is_target_entry "$product"; then
        is_target=true
        dim "  (building as SPM target — MACH_O_TYPE=mh_dylib)"
    fi

    # --- Parallel device + simulator build ---
    info "  Building $product — device (arm64) + simulator (parallel)..."

    run_xcodebuild_archive "$source_dir" "$scheme" "generic/platform=iOS" "$device_archive" "$derived_data/device" "$device_log" "$is_target" &
    local device_pid=$!

    run_xcodebuild_archive "$source_dir" "$scheme" "generic/platform=iOS Simulator" "$sim_archive" "$derived_data/simulator" "$sim_log" "$is_target" &
    local sim_pid=$!

    local device_rc=0 sim_rc=0
    wait $device_pid || device_rc=$?
    wait $sim_pid || sim_rc=$?

    # Show build result summaries (after both complete to avoid interleaving)
    if [[ -f "$device_log" ]]; then
        tail -5 "$device_log"
    fi
    if [[ -f "$sim_log" ]]; then
        tail -5 "$sim_log"
    fi

    # --- Handle device failure ---
    if [[ $device_rc -ne 0 ]]; then
        # Check if the failure is due to missing scheme
        if [[ -f "$device_log" ]] && grep -q "does not contain a scheme" "$device_log"; then
            if $HAS_XCODEPROJ; then
                dim "  Scheme '$scheme' not in xcodeproj — retrying in SPM mode..."
                # Move xcodeproj aside and retry sequentially with product name as scheme
                local xcproj
                for xcproj in "$source_dir"/*.xcodeproj "$source_dir"/*.xcworkspace; do
                    [[ -e "$xcproj" ]] && mv "$xcproj" "${xcproj}.aside"
                done

                info "  Building $product — device (arm64) [SPM mode]..."
                if ! run_xcodebuild_archive "$source_dir" "$product" "generic/platform=iOS" "$device_archive" "$derived_data/device" "$device_log" "$is_target"; then
                    warn "  Device build failed in both xcodeproj and SPM modes"
                    if [[ -f "$device_log" ]] && ! $VERBOSE; then
                        warn "  Last 15 lines of build output:"
                        tail -15 "$device_log" | sed 's/^/    /'
                    fi
                    for xcproj in "$source_dir"/*.aside; do
                        [[ -e "$xcproj" ]] && mv "$xcproj" "${xcproj%.aside}"
                    done
                    return 1
                fi
                tail -5 "$device_log"

                info "  Building $product — simulator [SPM mode]..."
                if ! run_xcodebuild_archive "$source_dir" "$product" "generic/platform=iOS Simulator" "$sim_archive" "$derived_data/simulator" "$sim_log" "$is_target"; then
                    warn "  Simulator build failed in SPM mode"
                    if [[ -f "$sim_log" ]] && ! $VERBOSE; then
                        warn "  Last 15 lines of build output:"
                        tail -15 "$sim_log" | sed 's/^/    /'
                    fi
                    for xcproj in "$source_dir"/*.aside; do
                        [[ -e "$xcproj" ]] && mv "$xcproj" "${xcproj%.aside}"
                    done
                    return 1
                fi
                tail -5 "$sim_log"

                # Restore xcodeproj for future products
                for xcproj in "$source_dir"/*.aside; do
                    [[ -e "$xcproj" ]] && mv "$xcproj" "${xcproj%.aside}"
                done
                return 0
            fi
        fi

        warn "  Device build failed"
        if [[ -f "$device_log" ]] && ! $VERBOSE; then
            warn "  Last 15 lines of build output:"
            tail -15 "$device_log" | sed 's/^/    /'
        fi
        return 1
    fi

    # --- Handle simulator failure ---
    if [[ $sim_rc -ne 0 ]]; then
        warn "  Simulator build failed"
        if [[ -f "$sim_log" ]] && ! $VERBOSE; then
            warn "  Last 15 lines of build output:"
            tail -15 "$sim_log" | sed 's/^/    /'
        fi
        return 1
    fi

    return 0
}

# Detect system framework dependencies from source code and SPM package metadata.
# Scans target source files for #import <Framework/...> and @import Framework,
# and checks linkedFramework entries in the package dump.
# Arguments: source_dir dump_file product_name
# Outputs: framework names on stdout, one per line
detect_system_frameworks() {
    local source_dir="$1" dump_file="$2" product="$3"

    [[ -f "$dump_file" ]] || return 0

    python3 - "$dump_file" "$product" "$source_dir" << 'PYEOF'
import json, sys, os, re

dump_file, product_name, source_dir = sys.argv[1:4]
pkg = json.load(open(dump_file))
targets = {t["name"]: t for t in pkg.get("targets", [])}

frameworks = set()
product_targets = []
for p in pkg.get("products", []):
    if p["name"] == product_name:
        product_targets = p.get("targets", [])
        break

# Fallback for --target entries: the name won't match any .library() product
# but should exist directly in targets[]. Treat the target itself as the list.
if not product_targets and product_name in targets:
    product_targets = [product_name]

def scan_target(tname):
    """Scan a target for linkedFramework settings and source imports."""
    t = targets.get(tname, {})
    if not t:
        return

    # linkedFramework from SPM linker settings
    for s in t.get("settings", []):
        if s.get("tool") == "linker":
            kind = s.get("kind", {})
            if isinstance(kind, dict):
                fw = kind.get("linkedFramework")
                if fw:
                    frameworks.add(fw)

    # Scan target source files for #import <Framework/...> and @import Framework
    tpath = os.path.normpath(os.path.join(source_dir, t.get("path", "")))
    if not os.path.isdir(tpath):
        return
    exclude = {"Tests", "Demo", "Example", "Examples", "Samples", "Playground"}
    for root, dirs, files in os.walk(tpath):
        dirs[:] = [d for d in dirs if d not in exclude]
        for f in files:
            if not f.endswith((".h", ".m", ".mm")):
                continue
            try:
                content = open(os.path.join(root, f), "r", errors="replace").read()
                for m in re.finditer(r'#import\s*<([A-Za-z_]+)/', content):
                    frameworks.add(m.group(1))
                for m in re.finditer(r'@import\s+([A-Za-z_]+)', content):
                    frameworks.add(m.group(1))
            except:
                pass

# Scan direct product targets and their first-level internal dependencies
scanned = set()
for tname in product_targets:
    if tname not in scanned:
        scan_target(tname)
        scanned.add(tname)
    # Walk first-level dependencies (same pattern as inject_objc_headers)
    t = targets.get(tname, {})
    for dep in t.get("dependencies", []):
        dep_name = dep.get("byName", [None])[0] if isinstance(dep.get("byName"), list) else None
        if dep_name and dep_name in targets and dep_name not in scanned:
            scan_target(dep_name)
            scanned.add(dep_name)

# Remove self-references
frameworks.discard(product_name)
for tname in scanned:
    frameworks.discard(tname)

for fw in sorted(frameworks):
    print(fw)
PYEOF
}

# Promote a static archive (.a) to a dynamic framework bundle.
#
# Some SPM packages (especially ObjC-only ones like MBProgressHUD) produce
# static archives even when patched to type: .dynamic. This function re-links
# the .a into a dynamic library and wraps it in a .framework bundle.
#
# Arguments: static_lib product_name sdk_name min_ios archive_path
promote_static_to_framework() {
    local static_lib="$1" product="$2" sdk_name="$3" min_ios="$4" archive_path="$5"

    local fw_dir="$archive_path/Products/Library/Frameworks/${product}.framework"
    rm -rf "$fw_dir"
    mkdir -p "$fw_dir"

    # Determine architectures from the static library
    local archs
    archs=$(lipo -archs "$static_lib" 2>/dev/null)
    if [[ -z "$archs" ]]; then
        warn "  Failed to determine architectures from $static_lib"
        return 1
    fi

    local min_ver_flag="-miphoneos-version-min=${min_ios}"
    [[ "$sdk_name" == iphonesimulator ]] && min_ver_flag="-mios-simulator-version-min=${min_ios}"

    dim "  Re-linking static → dynamic ($sdk_name: $archs)"

    # Build linker command with architecture flags
    local link_cmd=(
        xcrun --sdk "$sdk_name" clang -dynamiclib
    )
    for a in $archs; do
        link_cmd+=(-arch "$a")
    done
    link_cmd+=(
        "$min_ver_flag"
        -install_name "@rpath/${product}.framework/${product}"
        -Xlinker -all_load
        "$static_lib"
    )

    # Detect and explicitly link system frameworks the library imports
    local detected_fws
    detected_fws=$(detect_system_frameworks "$WORK_DIR/source" "$WORK_DIR/package-dump.json" "$product")
    if [[ -n "$detected_fws" ]]; then
        verbose_log "  Linking system frameworks: $(echo $detected_fws | tr '\n' ' ')"
        while IFS= read -r fw; do
            [[ -n "$fw" ]] && link_cmd+=(-framework "$fw")
        done <<< "$detected_fws"
    fi

    # Safety net for any remaining unresolved symbols (e.g. indirect deps)
    link_cmd+=(-Xlinker -undefined -Xlinker dynamic_lookup)
    link_cmd+=(-o "$fw_dir/$product")

    local link_log="$archive_path/relink.log"
    local link_rc=0
    "${link_cmd[@]}" > "$link_log" 2>&1 || link_rc=$?

    if [[ $link_rc -ne 0 ]]; then
        warn "  Failed to re-link static library as dynamic framework"
        tail -5 "$link_log" | sed 's/^/    /'
        return 1
    fi

    # Create minimal Info.plist (required for valid framework bundle)
    cat > "$fw_dir/Info.plist" << PLIST
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleExecutable</key>
    <string>${product}</string>
    <key>CFBundleIdentifier</key>
    <string>com.spm-to-xcframework.${product}</string>
    <key>CFBundleName</key>
    <string>${product}</string>
    <key>CFBundlePackageType</key>
    <string>FMWK</string>
    <key>MinimumOSVersion</key>
    <string>${min_ios}</string>
</dict>
</plist>
PLIST

    return 0
}

# Build a single product for device and simulator, create xcframework.
# Arguments: product_name
build_product() {
    local product="$1"
    local source_dir="$WORK_DIR/source"
    local archives_dir="$WORK_DIR/archives/$product"
    local derived_data="$WORK_DIR/DerivedData/$product"
    local output_xcfw="$OUTPUT_DIR/${product}.xcframework"

    # Find the scheme
    local scheme
    scheme=$(find_scheme_for_product "$product")
    if [[ "$scheme" != "$product" ]]; then
        dim "  Using scheme: $scheme"
    fi

    mkdir -p "$archives_dir"

    # --- Build for device and simulator ---
    if ! build_archive "$source_dir" "$scheme" "$product" "$archives_dir" "$derived_data"; then
        return 1
    fi

    local device_archive="$archives_dir/${product}-ios-arm64.xcarchive"
    local sim_archive="$archives_dir/${product}-ios-simulator.xcarchive"

    # --- Find frameworks in archives ---
    local device_fw simulator_fw
    device_fw=$(find "$device_archive/Products" -name "${product}.framework" -type d 2>/dev/null | head -1)
    simulator_fw=$(find "$sim_archive/Products" -name "${product}.framework" -type d 2>/dev/null | head -1)

    if [[ -z "$device_fw" ]]; then
        # The framework name might differ from the product name — search for any framework
        warn "  ${product}.framework not found in device archive, searching..."
        local found_fws
        found_fws=$(find "$device_archive/Products" -name "*.framework" -type d 2>/dev/null)
        if [[ -n "$found_fws" ]]; then
            dim "  Found frameworks in archive:"
            echo "$found_fws" | sed 's/^/    /'
            # Take the first one as a best guess
            device_fw=$(echo "$found_fws" | head -1)
            local actual_name
            actual_name=$(basename "$device_fw" .framework)
            simulator_fw=$(find "$sim_archive/Products" -name "${actual_name}.framework" -type d 2>/dev/null | head -1)
            warn "  Using $actual_name instead of $product"
        else
            # No frameworks — check for static archives (.a) to promote to dynamic
            local device_static=""

            # Search by product name
            device_static=$(find "$device_archive/Products" -name "lib${product}.a" -type f 2>/dev/null | head -1)

            # Search by SPM target names from package metadata
            if [[ -z "$device_static" ]]; then
                while IFS= read -r tname; do
                    [[ -z "$tname" || "$tname" == "$product" ]] && continue
                    device_static=$(find "$device_archive/Products" -name "lib${tname}.a" -type f 2>/dev/null | head -1)
                    [[ -n "$device_static" ]] && break
                done < <(python3 -c "
import json, sys
pkg = json.load(open(sys.argv[1]))
for p in pkg.get('products', []):
    if p['name'] == sys.argv[2]:
        for t in p.get('targets', []):
            print(t)
" "$WORK_DIR/package-dump.json" "$product" 2>/dev/null)
            fi

            # Last resort: any .a, but fail if ambiguous
            if [[ -z "$device_static" ]]; then
                local found_a=()
                while IFS= read -r afile; do
                    [[ -n "$afile" ]] && found_a+=("$afile")
                done < <(find "$device_archive/Products" -name "*.a" -type f 2>/dev/null)

                if [[ ${#found_a[@]} -eq 1 ]]; then
                    device_static="${found_a[0]}"
                elif [[ ${#found_a[@]} -gt 1 ]]; then
                    warn "  Multiple static libraries found — cannot determine which to promote:"
                    printf '    %s\n' "${found_a[@]}"
                    return 1
                fi
            fi

            if [[ -n "$device_static" ]]; then
                warn "  Static library found — promoting to dynamic framework"
                # Find matching simulator static library by same filename
                local sim_static
                sim_static=$(find "$sim_archive/Products" -name "$(basename "$device_static")" -type f 2>/dev/null | head -1)

                if [[ -z "$sim_static" ]]; then
                    warn "  No matching static library found in simulator archive"
                    return 1
                fi

                if ! promote_static_to_framework "$device_static" "$product" "iphoneos" "$MIN_IOS" "$device_archive"; then
                    return 1
                fi
                if ! promote_static_to_framework "$sim_static" "$product" "iphonesimulator" "$MIN_IOS" "$sim_archive"; then
                    return 1
                fi

                device_fw=$(find "$device_archive/Products" -name "${product}.framework" -type d 2>/dev/null | head -1)
                simulator_fw=$(find "$sim_archive/Products" -name "${product}.framework" -type d 2>/dev/null | head -1)

                if [[ -z "$device_fw" || -z "$simulator_fw" ]]; then
                    warn "  Framework promotion from static library failed"
                    return 1
                fi
            else
                warn "  No frameworks or static libraries found in device archive"
                return 1
            fi
        fi
    fi

    if [[ -z "$simulator_fw" ]]; then
        warn "  Framework not found in simulator archive"
        return 1
    fi

    # Resolve the actual framework name (may differ from product name)
    local fw_name
    fw_name=$(basename "$device_fw" .framework)

    # --- Inject Swift module interfaces if missing ---
    inject_swiftmodule "$fw_name" "$scheme" "$device_fw" "$derived_data/device" "device"
    inject_swiftmodule "$fw_name" "$scheme" "$simulator_fw" "$derived_data/simulator" "simulator"

    # --- Inject ObjC headers if missing ---
    inject_objc_headers "$product" "$fw_name" "$device_fw" "$source_dir" "$WORK_DIR/package-dump.json"
    inject_objc_headers "$product" "$fw_name" "$simulator_fw" "$source_dir" "$WORK_DIR/package-dump.json"

    # --- Create xcframework ---
    info "  Creating ${product}.xcframework..."
    rm -rf "$output_xcfw"

    local create_cmd=(
        xcodebuild -create-xcframework
        -framework "$device_fw"
        -framework "$simulator_fw"
        -output "$output_xcfw"
    )

    if ! "${create_cmd[@]}" 2>&1 | tail -3; then
        warn "  Failed to create ${product}.xcframework"
        return 1
    fi

    # --- Validate the xcframework (advisory — warnings only) ---
    validate_xcframework "$fw_name" "$output_xcfw"

    # Export resolved framework name for --include-deps callers
    LAST_BUILT_FW_NAME="$fw_name"

    success "  ${product}.xcframework ready [$FW_TYPE]"
    return 0
}

# Build dependency xcframeworks (when --include-deps is set).
# Scans archives for frameworks beyond the main product.
# Arguments: product_name resolved_fw_name
build_dependency_xcframeworks() {
    local product="$1"
    local primary_fw_name="${2:-$product}"
    local archives_dir="$WORK_DIR/archives/$product"
    local derived_data="$WORK_DIR/DerivedData/$product"

    local device_archive="$archives_dir/${product}-ios-arm64.xcarchive"
    local sim_archive="$archives_dir/${product}-ios-simulator.xcarchive"

    [[ -d "$device_archive" ]] || return 0

    # Find all frameworks in the device archive that aren't the primary
    # (skip by both product name and resolved fw_name to handle remaps)
    while IFS= read -r fw_path; do
        local fw_name
        fw_name=$(basename "$fw_path" .framework)
        [[ "$fw_name" == "$product" || "$fw_name" == "$primary_fw_name" ]] && continue
        [[ -f "$OUTPUT_DIR/${fw_name}.xcframework/Info.plist" ]] && continue

        local sim_fw
        sim_fw=$(find "$sim_archive/Products" -name "${fw_name}.framework" -type d 2>/dev/null | head -1)
        [[ -z "$sim_fw" ]] && continue

        dim "  Dependency: ${fw_name}"

        # Inject swiftmodule and ObjC headers if needed
        inject_swiftmodule "$fw_name" "$fw_name" "$fw_path" "$derived_data/device" "device"
        inject_swiftmodule "$fw_name" "$fw_name" "$sim_fw" "$derived_data/simulator" "simulator"
        inject_objc_headers "$fw_name" "$fw_name" "$fw_path" "$WORK_DIR/source" "$WORK_DIR/package-dump.json"
        inject_objc_headers "$fw_name" "$fw_name" "$sim_fw" "$WORK_DIR/source" "$WORK_DIR/package-dump.json"

        local dep_xcfw="$OUTPUT_DIR/${fw_name}.xcframework"
        if xcodebuild -create-xcframework \
            -framework "$fw_path" \
            -framework "$sim_fw" \
            -output "$dep_xcfw" 2>&1 | tail -1; then
            detect_framework_type "$dep_xcfw"
            success "  ${fw_name}.xcframework ready (dependency) [$FW_TYPE]"
        else
            warn "  Failed to create ${fw_name}.xcframework (dependency)"
        fi
    done < <(find "$device_archive/Products" -name "*.framework" -type d 2>/dev/null)
}

# Inject .swiftmodule/.swiftinterface into a framework if missing.
inject_swiftmodule() {
    local product="$1" scheme="$2" fw_path="$3" dd_path="$4" variant="$5"

    local fw_name
    fw_name=$(basename "$fw_path" .framework)

    # Check if swiftmodule already exists in the framework
    if [[ -d "$fw_path/Modules/${fw_name}.swiftmodule" ]]; then
        # Check if it has .swiftinterface files (not just .swiftmodule binary)
        if find "$fw_path/Modules/${fw_name}.swiftmodule" -name "*.swiftinterface" 2>/dev/null | grep -q .; then
            verbose_log "  Swift interfaces present in $variant framework"
            return 0
        fi
    fi

    # Search DerivedData for the swiftmodule
    local swiftmod
    swiftmod=$(find "$dd_path" \
        -path "*/${fw_name}.swiftmodule" \
        -type d \
        2>/dev/null | head -1)

    # Also try searching with the scheme name
    if [[ -z "$swiftmod" && "$scheme" != "$fw_name" ]]; then
        swiftmod=$(find "$dd_path" \
            -path "*/ArchiveIntermediates/${scheme}/BuildProductsPath/*/${fw_name}.swiftmodule" \
            -type d \
            2>/dev/null | head -1)
    fi

    if [[ -n "$swiftmod" ]]; then
        dim "  Injecting Swift module interfaces ($variant)"
        mkdir -p "$fw_path/Modules"
        cp -R "$swiftmod" "$fw_path/Modules/"
    else
        verbose_log "  No Swift module found in DerivedData for $fw_name ($variant)"
    fi
}

# Inject ObjC public headers and modulemap into a framework bundle.
# SPM ObjC targets don't include headers in the archive Products — we pull
# them from the source tree using Package.swift metadata (package-dump.json).
# Arguments: product_name fw_name fw_path source_dir dump_file
inject_objc_headers() {
    local product="$1" fw_name="$2" fw_path="$3" source_dir="$4" dump_file="$5"

    # Skip if framework already has public headers (excluding auto-generated Swift bridging headers)
    if find "$fw_path/Headers" -name "*.h" ! -name "*-Swift.h" 2>/dev/null | grep -q .; then
        verbose_log "  Public headers already present in framework"
        return 0
    fi

    # Skip if no package dump available
    [[ -f "$dump_file" ]] || return 0

    # Use package dump to find the public headers path for the product's target(s).
    # Priority: target matching fw_name > target matching product name > first target with headers.
    # Also checks first-level dependencies if direct targets have no headers.
    local headers_dir
    headers_dir=$(python3 - "$dump_file" "$product" "$fw_name" "$source_dir" << 'PYEOF'
import json, sys, os

dump_file, product_name, fw_name, source_dir = sys.argv[1:5]
pkg = json.load(open(dump_file))
targets = {t["name"]: t for t in pkg.get("targets", [])}

product_targets = []
for p in pkg.get("products", []):
    if p["name"] == product_name:
        product_targets = p.get("targets", [])
        break

# Fallback for --target entries: name exists in targets[] but not as a .library() product.
if not product_targets and product_name in targets:
    product_targets = [product_name]

if not product_targets:
    sys.exit(0)

def find_headers_dir(target_name):
    t = targets.get(target_name)
    if not t or not t.get("publicHeadersPath"):
        return None
    path = t.get("path", "")
    php = t["publicHeadersPath"]
    full_path = os.path.normpath(os.path.join(source_dir, path, php))
    if not os.path.isdir(full_path):
        return None
    if any(f.endswith(".h") for _, _, files in os.walk(full_path) for f in files):
        return full_path
    return None

# Check direct product targets
best = None
for tname in product_targets:
    d = find_headers_dir(tname)
    if not d:
        continue
    if tname == fw_name:
        best = d
        break
    elif tname == product_name and not best:
        best = d
    elif not best:
        best = d

# If no direct target has headers, check first-level dependencies
if not best:
    for tname in product_targets:
        t = targets.get(tname)
        if not t:
            continue
        for dep in t.get("dependencies", []):
            dep_name = dep.get("byName", [None])[0]
            if not dep_name:
                continue
            d = find_headers_dir(dep_name)
            if d:
                if dep_name in (fw_name, product_name):
                    best = d
                    break
                elif not best:
                    best = d
        if best:
            break

if best:
    print(best)
PYEOF
    )

    if [[ -z "$headers_dir" || ! -d "$headers_dir" ]]; then
        verbose_log "  No ObjC public headers found in source tree for $fw_name"
        return 0
    fi

    dim "  Injecting ObjC headers ($fw_name)"

    # Copy headers into framework.
    # SPM convention: headers may be in a subdirectory named after the module
    # (e.g., Public/FirebaseCore/*.h) or directly in the public headers dir.
    mkdir -p "$fw_path/Headers"
    local module_subdir="$headers_dir/$fw_name"
    if [[ -d "$module_subdir" ]]; then
        find "$module_subdir" -name "*.h" -exec cp {} "$fw_path/Headers/" \;
    else
        find "$headers_dir" -maxdepth 1 -name "*.h" -exec cp {} "$fw_path/Headers/" \;
    fi

    local header_count
    header_count=$(find "$fw_path/Headers" -name "*.h" 2>/dev/null | wc -l | tr -d ' ')
    if [[ "$header_count" -eq 0 ]]; then
        verbose_log "  No headers copied from $headers_dir"
        return 0
    fi

    # Generate modulemap
    mkdir -p "$fw_path/Modules"
    local umbrella_header="$fw_path/Headers/${fw_name}.h"
    if [[ -f "$umbrella_header" ]]; then
        cat > "$fw_path/Modules/module.modulemap" << MODMAP
framework module ${fw_name} {
  umbrella header "${fw_name}.h"
  export *
  module * { export * }
}
MODMAP
    else
        # No umbrella header — list all headers explicitly
        {
            echo "framework module ${fw_name} {"
            find "$fw_path/Headers" -name "*.h" -exec basename {} \; | sort | while read -r h; do
                echo "  header \"$h\""
            done
            echo "  export *"
            echo "}"
        } > "$fw_path/Modules/module.modulemap"
    fi

    verbose_log "  Injected $header_count header(s) + modulemap"
}

# --- Framework Type Detection ---

# Detect whether an xcframework contains Swift, ObjC, or both.
# Sets FW_TYPE to "Swift", "ObjC", or "Mixed" and prints a label.
# Arguments: xcfw_path
# Returns: sets FW_TYPE global
FW_TYPE=""

detect_framework_type() {
    local xcfw_path="$1"

    local has_swift=false
    local has_objc=false

    # Swift: look for .swiftinterface or .swiftmodule
    if find "$xcfw_path" -name "*.swiftinterface" 2>/dev/null | grep -q .; then
        has_swift=true
    elif find "$xcfw_path" -name "*.swiftmodule" -type d 2>/dev/null | grep -q .; then
        has_swift=true
    fi

    # ObjC: look for public headers (.h files inside a Headers/ directory).
    # Exclude generated *-Swift.h headers — these are auto-generated ObjC
    # interfaces for Swift modules, not actual ObjC API.
    if find "$xcfw_path" -path "*/Headers/*.h" ! -name "*-Swift.h" 2>/dev/null | grep -q .; then
        has_objc=true
    fi

    if $has_swift && $has_objc; then
        FW_TYPE="Mixed"
    elif $has_swift; then
        FW_TYPE="Swift"
    elif $has_objc; then
        FW_TYPE="ObjC"
    else
        FW_TYPE="Unknown"
    fi
}

# --- Validation ---

# Advisory validation — warns about issues but does not fail the build.
# Partially usable xcframeworks (e.g. missing swiftinterface for ObjC modules)
# are still valuable, so this is intentionally warn-only.
# Arguments: framework_binary_name xcfw_path
validate_xcframework() {
    local fw_name="$1" xcfw_path="$2"
    local issues=0

    # Detect framework type first
    detect_framework_type "$xcfw_path"

    # Check for at least two architecture slices (device + simulator)
    local slices
    slices=$(find "$xcfw_path" -name "*.framework" -type d -maxdepth 2 2>/dev/null | wc -l)
    if [[ $slices -lt 2 ]]; then
        warn "  Warning: Expected 2 slices (device + simulator), found $slices"
        issues=$((issues + 1))
    fi

    # Swift-specific: check for swiftinterface files
    if [[ "$FW_TYPE" == "Swift" || "$FW_TYPE" == "Mixed" ]]; then
        local interfaces
        interfaces=$(find "$xcfw_path" -name "*.swiftinterface" 2>/dev/null | wc -l)
        if [[ $interfaces -eq 0 ]]; then
            warn "  Warning: No .swiftinterface files — Swift bindings require ABI JSON (generated from swiftinterface)"
            issues=$((issues + 1))
        fi
    fi

    # ObjC-specific: check for headers and modulemap
    if [[ "$FW_TYPE" == "ObjC" || "$FW_TYPE" == "Mixed" ]]; then
        local headers
        headers=$(find "$xcfw_path" -path "*/Headers/*.h" ! -name "*-Swift.h" 2>/dev/null | wc -l)
        if [[ $headers -eq 0 ]]; then
            warn "  Warning: No public headers found — ObjC bindings require headers"
            issues=$((issues + 1))
        else
            verbose_log "  Public headers present ($headers files)"
        fi

        local modulemap
        modulemap=$(find "$xcfw_path" -name "module.modulemap" -o -name "*.modulemap" 2>/dev/null | head -1)
        if [[ -n "$modulemap" ]]; then
            verbose_log "  Modulemap present"
        else
            warn "  Warning: No modulemap found — ObjC bindings may need manual header specification"
            issues=$((issues + 1))
        fi
    fi

    # Unknown type: no Swift interfaces and no ObjC headers
    if [[ "$FW_TYPE" == "Unknown" ]]; then
        warn "  Warning: No .swiftinterface files or public headers found — binding generation may not work"
        issues=$((issues + 1))
    fi

    # Check for dynamic library — find the binary inside any .framework slice.
    # The binary name matches the framework name (fw_name), not necessarily
    # the SPM product name.
    local dylib
    dylib=$(find "$xcfw_path" -path "*/${fw_name}.framework/${fw_name}" -type f 2>/dev/null | head -1)
    if [[ -n "$dylib" ]]; then
        local file_type
        file_type=$(file "$dylib" 2>/dev/null | head -1)
        if echo "$file_type" | grep -q "dynamically linked"; then
            verbose_log "  Verified: dynamic library"
        elif echo "$file_type" | grep -q "current ar archive"; then
            warn "  Warning: Static library detected — P/Invoke requires dynamic (.dylib)"
            issues=$((issues + 1))
        fi
    else
        warn "  Warning: No binary named '$fw_name' found in xcframework"
        issues=$((issues + 1))
    fi

    # Check for abi.json (generated alongside swiftinterface with library evolution)
    if [[ "$FW_TYPE" == "Swift" || "$FW_TYPE" == "Mixed" ]]; then
        local abi_files
        abi_files=$(find "$xcfw_path" -name "*.abi.json" 2>/dev/null | wc -l)
        if [[ $abi_files -gt 0 ]]; then
            verbose_log "  ABI JSON present ($abi_files files)"
        else
            verbose_log "  No ABI JSON in xcframework (will be generated from swiftinterface at bind time)"
        fi
    fi

    if [[ $issues -gt 0 ]]; then
        verbose_log "  Validation: $issues warning(s)"
    fi
    return 0
}

# --- Main ---

main() {
    parse_args "$@"

    bold "spm-to-xcframework"
    echo ""

    # Verify prerequisites
    command -v xcodebuild >/dev/null 2>&1 || die "xcodebuild not found. Install Xcode and command line tools."
    command -v swift >/dev/null 2>&1 || die "swift not found. Install Xcode and command line tools."
    command -v python3 >/dev/null 2>&1 || die "python3 not found."

    # Create working directory
    WORK_DIR=$(mktemp -d "${TMPDIR:-/tmp}/spm-to-xcfw.XXXXXXXX")
    verbose_log "Work directory: $WORK_DIR"

    # Create output directory
    mkdir -p "$OUTPUT_DIR"
    OUTPUT_DIR=$(cd "$OUTPUT_DIR" && pwd)  # Absolutize

    # Normalize version tag once (handles v-prefix fallback) before any code uses VERSION
    normalize_version_tag

    # Binary mode — download pre-built xcframeworks and exit
    if $BINARY_MODE; then
        is_remote || die "--binary requires a remote package URL"
        [[ -n "$VERSION" ]] || die "--binary requires --version"
        # --target is a source-build escape hatch; binary mode has no SPM library-vs-target
        # distinction — the package just publishes named xcframework artifacts. Reject rather
        # than silently ignore the flag.
        if [[ ${#TARGET_FILTERS[@]} -gt 0 ]]; then
            die "--target is not supported with --binary (binary mode has no concept of SPM library vs target — use --product to filter artifact names)"
        fi
        if [[ -n "$REVISION" ]]; then
            verify_revision "$PACKAGE_SOURCE" "$VERSION" "$REVISION"
        fi

        fetch_binary_artifacts

        echo ""
        bold "=== Summary ==="
        if [[ $BUILT -gt 0 ]]; then success "  Copied: $BUILT"; fi
        bold "Output: $OUTPUT_DIR"
        echo ""
        exit 0
    fi

    # Step 1: Fetch source
    fetch_source

    # Step 2: Discover products
    discover_products

    # Step 3: Discover schemes
    discover_schemes

    # Patch Package.swift to make all library products dynamic frameworks.
    # This replaces the old MACH_O_TYPE=mh_dylib global override which broke
    # internal C/ObjC dependency targets (nanopb, leveldb, GoogleUtilities, etc.).
    patch_dynamic_libraries "$WORK_DIR/source/Package.swift"

    # Dry run — just show what we'd build
    if $DRY_RUN; then
        bold "Dry run — would build:"
        for product in "${PRODUCTS[@]}"; do
            local scheme kind_label=""
            scheme=$(find_scheme_for_product "$product")
            if is_target_entry "$product"; then
                kind_label=" [target, mh_dylib]"
            fi
            echo "  $product (scheme: $scheme) → $OUTPUT_DIR/${product}.xcframework${kind_label}"
        done
        echo ""
        if $INCLUDE_DEPS; then
            echo "  Dependency xcframeworks would also be extracted."
        fi
        exit 0
    fi

    # Step 4: Build each product
    echo ""
    bold "Building xcframeworks..."
    echo ""

    for product in "${PRODUCTS[@]}"; do
        bold "[$((BUILT + FAILED + SKIPPED + 1))/${#PRODUCTS[@]}] $product"

        if build_product "$product"; then
            BUILT=$((BUILT + 1))

            # Extract dependency xcframeworks if requested
            if $INCLUDE_DEPS; then
                build_dependency_xcframeworks "$product" "$LAST_BUILT_FW_NAME"
            fi
        else
            FAILED=$((FAILED + 1))
            warn "  Failed to build $product"
        fi
        echo ""
    done

    # --- Summary ---
    echo ""
    bold "=== Summary ==="
    if [[ $BUILT -gt 0 ]]; then success "  Built: $BUILT"; fi
    if [[ $FAILED -gt 0 ]]; then echo -e "  ${RED}Failed: $FAILED${NC}"; fi
    if [[ $SKIPPED -gt 0 ]]; then dim "  Skipped: $SKIPPED"; fi
    echo ""
    bold "Output: $OUTPUT_DIR"

    if [[ $BUILT -gt 0 ]]; then
        echo ""
        dim "Xcframeworks:"
        find "$OUTPUT_DIR" -name "*.xcframework" -maxdepth 1 -type d | sort | while read -r fw; do
            local name
            name=$(basename "$fw")
            local size
            size=$(du -sh "$fw" 2>/dev/null | cut -f1)
            detect_framework_type "$fw"
            echo "  $name ($size) [$FW_TYPE]"
        done
    fi

    echo ""

    [[ $FAILED -eq 0 ]] || exit 1
}

main "$@"
